# ================================================
# 琪露诺 CLI 环境变量模板（中文注释版）
# 用法：
# 1) 复制本文件为 .env
# 2) 只改“必填项”，其余保持默认即可运行
# 3) 修改后重启程序：python app.py
# ================================================

# [必填] DeepSeek API 密钥
# 获取方式：DeepSeek 控制台创建 API Key
# 常见错误：
# - 留成占位文字（会鉴权失败）
# - 前后有空格或引号（可能鉴权失败）
DEEPSEEK_API_KEY=请替换为你的真实APIKey

# [通常不改] DeepSeek OpenAI 兼容接口地址
# 仅在你使用代理/网关时才改
DEEPSEEK_BASE_URL=https://api.deepseek.com

# [可选] 终端显示昵称
USER_NAME=你

# [通常不改] 模型名
# 不确定时使用 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# [可选] 本地数据目录
# 将存放：memory.db / chat_samples.jsonl / feedback_events.jsonl
DATA_DIR=data

# [建议默认] 最近对话窗口轮数（上下文短期记忆）
# 越大越“记得住最近内容”，但 token 成本更高
# 推荐范围：6~10
MAX_RECENT_TURNS=8

# [建议默认] 注入长期事实的最大条数
# 越大信息越全，但提示词更长
# 推荐范围：6~12
MAX_FACTS=8

# [建议默认] 生成随机性
# 0.2~0.5 更稳定；0.6~0.9 更有风格
TEMPERATURE=0.7

# [建议默认] 每累计多少条消息触发一次摘要更新
# 注意：这里是“消息条数”，不是轮数
SUMMARY_EVERY_MESSAGES=6

# [建议默认] 记忆半衰期（天）
# 越大代表记忆保留更久；越小代表更偏近期
HALF_LIFE_DAYS=14

# [建议默认] 记忆过期阈值
# 有效分低于该值的事实会标记为过期
# 推荐范围：0.20~0.35
EXPIRE_THRESHOLD=0.25

# [可选] 是否显示样本 ID（用于数据调试）
# 日常聊天建议 false；调试数据采样可设为 true
# 可用值：true/false 或 yes/no 或 on/off 或 1/0
SHOW_SAMPLE_ID=false
