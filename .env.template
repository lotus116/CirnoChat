# ================================================
# 琪露诺 CLI 环境变量模板（中文注释版）
# 用法：
# 1) 复制本文件为 .env
# 2) 只改“必填项”，其余保持默认即可运行
# 3) 修改后重启程序：python app.py
# ================================================

# [通用] OpenAI 兼容 API 密钥
# 如果你用 Ollama，本地通常可随便填一个占位值，例如 ollama
# 如果你用 OpenAI / 兼容网关，再换成真实 Key
# 常见错误：
# - 留成占位文字（会鉴权失败）
# - 前后有空格或引号（可能鉴权失败）
OPENAI_API_KEY=ollama

# [常用] OpenAI 兼容接口地址
# Ollama 默认地址：http://127.0.0.1:11434/v1
# 如果你用 OpenAI / 网关 / 其他本地服务，改成对应的 OpenAI 兼容地址
OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# [可选] 终端显示昵称
USER_NAME=你

# [通常需要改] 模型名
# Ollama 示例：qwen2.5:3b-instruct / llama3.1:8b-instruct
OPENAI_MODEL=qwen2.5:3b-instruct

# [可选] 本地数据目录
# 将存放：memory.db / chat_samples.jsonl / feedback_events.jsonl
DATA_DIR=data

# [建议默认] 最近对话窗口轮数（上下文短期记忆）
# 越大越“记得住最近内容”，但 token 成本更高
# 推荐范围：6~10
MAX_RECENT_TURNS=8

# [建议默认] 注入长期事实的最大条数
# 越大信息越全，但提示词更长
# 推荐范围：6~12
MAX_FACTS=8

# [建议默认] 生成随机性
# 0.2~0.5 更稳定；0.6~0.9 更有风格
TEMPERATURE=0.7

# [建议默认] 每累计多少条消息触发一次摘要更新
# 注意：这里是“消息条数”，不是轮数
SUMMARY_EVERY_MESSAGES=6

# [建议默认] 记忆半衰期（天）
# 越大代表记忆保留更久；越小代表更偏近期
HALF_LIFE_DAYS=14

# [建议默认] 记忆过期阈值
# 有效分低于该值的事实会标记为过期
# 推荐范围：0.20~0.35
EXPIRE_THRESHOLD=0.25

# [可选] 是否显示样本 ID（用于数据调试）
# 日常聊天建议 false；调试数据采样可设为 true
# 可用值：true/false 或 yes/no 或 on/off 或 1/0
SHOW_SAMPLE_ID=false
