# 琪露诺 CLI 环境变量模板

# OpenAI 兼容 API Key。
# Ollama 本地服务通常可以直接写成占位值 `ollama`。
OPENAI_API_KEY=ollama

# OpenAI 兼容接口地址。
OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# 使用的模型名。
OPENAI_MODEL=qwen2.5:3b-instruct

# 终端里显示的用户名。
USER_NAME=你

# 本地数据目录。
DATA_DIR=data

# 最近短期上下文轮数。
MAX_RECENT_TURNS=8

# 注入到参考记忆里的最大事实条数。
MAX_FACTS=8

# 生成温度。
TEMPERATURE=0.7

# 每累计多少条消息触发一次摘要更新。
SUMMARY_EVERY_MESSAGES=6

# 事实记忆半衰期，单位天。
HALF_LIFE_DAYS=14

# 事实过期阈值。
EXPIRE_THRESHOLD=0.25

# 是否显示 sample_id。
SHOW_SAMPLE_ID=false

# 是否启用聊天采样落盘。
# 默认关闭，避免无意记录完整原始对话。
ENABLE_DATASET_LOGGING=false
